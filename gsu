# ── Internal helpers (for completions) ───────────────────────────────────────

_cmd_keys() {
  _all_keys
}

# ── Entry point ───────────────────────────────────────────────────────────────

main() {
  _ensure_config_dir

  local cmd="${1:-}"

  case "$cmd" in
    "")                       _migrate_legacy; cmd_show ;;
    current|show|whoami)      _migrate_legacy; cmd_show "${2:-}" ;;
    list|ls)                  cmd_list ;;
    use|switch)               cmd_use "${2:-}" ;;
    add|new)                  cmd_add "${2:-}" "${3:-}" "${4:-}" ;;
    remove|rm|delete|del)     cmd_remove "${2:-}" ;;
    edit|update-user)         cmd_edit "${2:-}" ;;
    token)                    cmd_token "${2:-}" "${3:-}" "${4:-}" ;;
    tokens)                   cmd_tokens "${2:-}" ;;
    token-remove|token-rm)    cmd_token_remove "${2:-}" "${3:-}" "${4:-}" ;;
    local)                    _migrate_legacy; cmd_local "${2:-}" ;;
    local-clear)              cmd_local_clear ;;
    export)                   cmd_export "${2:-}" ;;
    import)                   cmd_import "${2:-}" ;;
    update)                   cmd_update ;;
    version|-v|--version)     echo "gsu v$GSU_VERSION" ;;
    completions|completion)   cmd_completions "${2:-zsh}" ;;
    help|-h|--help)           cmd_help ;;
    _keys)                    _cmd_keys ;;   # internal — for completions
    *)
      # Direct user switch shorthand: gsu <key>
      _migrate_legacy
      if _user_exists "$cmd"; then
        cmd_use "$cmd"
      else
        err "Unknown command or user: '${cmd}'"
        echo "  Run ${BOLD}gsu help${NC} for usage, or ${BOLD}gsu list${NC} to see users." >&2
        exit 1
      fi
      ;;
  esac
}

main "$@"
